{
  "policy_id": "outward-copy-quality-gate/policy/v2",
  "plugin_version": "0.2.0",
  "required_hook_events": [
    "UserPromptSubmit"
  ],
  "routing_mode": "nonblocking_additional_context",
  "failure_mode": "fail_open_with_actionable_guidance",
  "required_scopes": [
    "title_headline",
    "readme",
    "seo_search",
    "public_docs",
    "repository_metadata",
    "marketing_sales",
    "product_ui_help",
    "general_outward_copy"
  ],
  "skills": [
    {
      "role": "router",
      "id": "outward-copy-quality-gate-router",
      "path": "skills/outward-copy-quality-gate-router/SKILL.md"
    },
    {
      "role": "humanizer",
      "id": "outward-copy-quality-gate-humanizer",
      "path": "skills/outward-copy-quality-gate-humanizer/SKILL.md"
    },
    {
      "role": "ogilvy",
      "id": "outward-copy-quality-gate-ogilvy",
      "path": "skills/outward-copy-quality-gate-ogilvy/SKILL.md"
    }
  ],
  "privacy": {
    "persist": [],
    "forbid": [
      "raw_prompt",
      "raw_copy",
      "private_message_body",
      "credential",
      "token",
      "cookie"
    ]
  },
  "enforcement_limits": [
    "Hooks must be enabled and trusted on each Codex installation.",
    "Codex does not expose a native skill-lifecycle event, so injected guidance cannot prove semantic skill use.",
    "This plugin routes work but never vetoes prompts or completion.",
    "Writers outside Codex and direct publication need separate review or CI controls."
  ]
}
