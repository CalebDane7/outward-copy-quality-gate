{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CalebDane7/outward-copy-quality-gate/blob/main/plugins/outward-copy-quality-gate/schemas/receipt.schema.json",
  "title": "Outward Copy Quality Gate receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "policy_id",
    "plugin_version",
    "status",
    "turn_key",
    "prompt_sha256",
    "output_sha256",
    "policy_sha256",
    "scopes",
    "copy_owner_evidence",
    "humanizer_evidence",
    "ogilvy_evidence",
    "skills",
    "created_at",
    "validated_at"
  ],
  "properties": {
    "schema": {
      "const": "outward-copy-quality-gate/receipt/v1"
    },
    "policy_id": {
      "const": "outward-copy-quality-gate/policy/v1"
    },
    "plugin_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "const": "validated"
    },
    "turn_key": {
      "$ref": "#/$defs/sha256"
    },
    "prompt_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "output_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "policy_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "copy_owner_evidence": {
      "type": "string",
      "pattern": "^owner:[a-z0-9][a-z0-9._-]{1,63}$"
    },
    "humanizer_evidence": {
      "type": "string",
      "pattern": "^humanizer:[a-z0-9][a-z0-9._-]{1,63}$"
    },
    "ogilvy_evidence": {
      "type": "string",
      "pattern": "^ogilvy:[a-z0-9][a-z0-9._-]{1,63}$"
    },
    "skills": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "sha256"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "sha256": {
            "$ref": "#/$defs/sha256"
          }
        }
      }
    },
    "created_at": {
      "type": "string"
    },
    "validated_at": {
      "type": "string"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
